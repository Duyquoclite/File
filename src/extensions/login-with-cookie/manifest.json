{
  "manifest_version": 3,
  "name": "Cookie Get/Set Tool",
  "version": "1.0",
  "description": "Extension cho phép lấy và dán cookie (hỗ trợ định dạng cookie|token).",
  "permissions": [
    "cookies",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Cookie Manager"
  }
}
