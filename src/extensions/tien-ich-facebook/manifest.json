{
  "manifest_version": 3,
  "name": "Tiện ích Facebook",
  "version": "1.0",
  "description": "Extension cho phép lấy/dán cookie và lấy mã bảo mật 2FA.(by quất đẹp trai)",
  "permissions": [
    "cookies",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tiện ích Facebook"
  }
}
